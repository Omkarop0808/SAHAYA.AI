# Server
PORT=5000
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Study World AI — Gemini (primary)
GEMINI_API_KEY=
# e.g. gemini-2.0-flash, gemini-2.5-flash — check Google AI Studio for current IDs
GEMINI_MODEL=gemini-2.0-flash

# Optional: Groq (fast free-tier fallback/primary)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Hugging Face (fallback if Gemini missing)
HF_API_KEY=
AI_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional: YouTube Data API v3 for real video recommendations in Smart Upload
YOUTUBE_API_KEY=

# Email (Gmail SMTP via Google App Password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_google_app_password_here
MAIL_FROM_NAME=Intelligent Learning AI Support

# Frontend URL (CORS) — Vite uses port 5005 in this repo
FRONTEND_URL=http://localhost:5005

# Optional: Force python executable used by /api/ai-predict (Windows example)
# PYTHON_BIN=C:\Python311\python.exe
